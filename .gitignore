# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.tmp-*/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.codex-*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local audit and planning docs
/docs/

# source migration material for the existing business site
docs/source-screenshots/*
!docs/source-screenshots/.gitkeep
docs/source-copy/*
!docs/source-copy/.gitkeep
docs/assets/private/*
docs/assets/source/*

# raw originals should be reviewed before becoming public website assets.
# Approved, optimised assets in public/images may be committed for deployment.
public/images/original/*
!public/images/original/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
