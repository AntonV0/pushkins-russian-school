# Browser-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Initial enquiry workflow. Defaults keep the public form validation-only:
# no real email sending and no enquiry storage unless explicitly configured.
ENQUIRY_STORAGE_MODE=disabled
SUPABASE_ENQUIRIES_TABLE=enquiries
ENQUIRY_DELIVERY_MODE=disabled
ENQUIRY_RATE_LIMIT_MODE=off
ENQUIRY_RATE_LIMIT_MAX=5
ENQUIRY_RATE_LIMIT_WINDOW_SECONDS=900
ENQUIRY_RATE_LIMIT_SALT=

# Server-only. Add only when an admin workflow needs it.
SUPABASE_SERVICE_ROLE_KEY=

# Future Stripe-hosted invoice payments. Leave blank until approved.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional future provider; not required for the Stripe-first milestone.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
